<%- include('../layouts/header', { title: 'Apply — ' + job.title }) %>
<div class="container-sm" style="padding-top:48px;padding-bottom:64px">
  <a href="/jobs/<%= job.id %>" class="text-sm text-muted" style="display:inline-block;margin-bottom:20px">← Back to job</a>

  <div class="page-header">
    <h1>Submit a proposal</h1>
    <p class="text-muted mt-8" style="font-size:15px">For: <strong><%= job.title %></strong></p>
  </div>

  <% if (errors && errors.length) { %>
    <div class="alert alert-error">
      <div>
        <% errors.forEach(e => { %><div>⚠ <%= e.msg %></div><% }) %>
      </div>
    </div>
  <% } %>

  <form action="/jobs/<%= job.id %>/apply" method="POST" novalidate>
    <div style="display:flex;flex-direction:column;gap:20px">
      <div class="grid-2" style="gap:16px">
        <div class="form-group">
          <label class="form-label">Your bid ($)</label>
          <input class="form-input" type="number" name="proposed_budget"
            value="<%= body.proposed_budget||'' %>" min="1" required placeholder="<%= job.budget_min %>">
          <span class="form-hint">Budget: $<%= Number(job.budget_min).toLocaleString() %>–$<%= Number(job.budget_max).toLocaleString() %></span>
        </div>
        <div class="form-group">
          <label class="form-label">Delivery time (days)</label>
          <input class="form-input" type="number" name="estimated_days"
            value="<%= body.estimated_days||'' %>" min="1" required placeholder="7">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Cover letter</label>
        <textarea class="form-textarea" name="cover_letter" rows="8" required
          placeholder="Why are you the perfect fit? What's your approach and relevant experience?"><%= body.cover_letter||'' %></textarea>
        <span class="form-hint">Minimum 100 characters.</span>
      </div>
      <div class="flex gap-12">
        <button type="submit" class="btn btn-primary">Send proposal</button>
        <a href="/freelancer/browse" class="btn btn-ghost">Cancel</a>
      </div>
    </div>
  </form>
</div>
<%- include('../layouts/footer') %>
<script src="/js/validate.js"></script>
