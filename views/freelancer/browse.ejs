<%- include('../layouts/header', { title: 'Browse Jobs' }) %>
<div class="container" style="padding-top:40px;padding-bottom:64px">

  <div class="flex items-center justify-between" style="margin-bottom:32px;flex-wrap:wrap;gap:16px">
    <div>
      <h1 style="font-family:var(--font-serif);font-size:36px">Find your next project</h1>
      <p class="text-muted mt-8">Browse open jobs matched to your skills.</p>
    </div>
    <a href="/freelancer/saved-jobs" class="btn btn-outline btn-sm">★ Saved jobs</a>
  </div>

  <!-- Filters -->
  <form method="GET" action="/freelancer/browse" class="card" style="padding:20px;margin-bottom:28px">
    <div style="display:grid;grid-template-columns:1fr auto auto;gap:12px;align-items:end;flex-wrap:wrap">
      <div class="form-group" style="margin:0">
        <label class="form-label">Search jobs</label>
        <input class="form-input" type="text" name="q" id="job-search" value="<%= q %>" placeholder="Brand designer, React developer…">
      </div>
      <div class="form-group" style="margin:0;min-width:160px">
        <label class="form-label">Category</label>
        <select class="form-select" name="category" id="category-filter">
          <option value="">All categories</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.slug %>" <%= category===c.slug?'selected':'' %>><%= c.icon %> <%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group" style="margin:0;min-width:130px">
        <label class="form-label">Level</label>
        <select class="form-select" name="level" id="level-filter">
          <option value="">All levels</option>
          <option value="entry"        <%= level==='entry'?'selected':'' %>>Entry</option>
          <option value="intermediate" <%= level==='intermediate'?'selected':'' %>>Intermediate</option>
          <option value="expert"       <%= level==='expert'?'selected':'' %>>Expert</option>
        </select>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:end;margin-top:12px">
      <div class="form-group" style="margin:0">
        <label class="form-label">Min budget ($)</label>
        <input class="form-input" type="number" name="budget_min" value="<%= budget_min %>" placeholder="0" min="0">
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Max budget ($)</label>
        <input class="form-input" type="number" name="budget_max" value="<%= budget_max %>" placeholder="Any" min="0">
      </div>
      <button type="submit" class="btn btn-primary" style="height:44px">Search</button>
    </div>
    <% if (q || category || level || budget_min || budget_max) { %>
      <div style="margin-top:10px">
        <a href="/freelancer/browse" class="text-sm text-muted">× Clear filters</a>
      </div>
    <% } %>
  </form>

  <div class="flex items-center justify-between" style="margin-bottom:20px">
    <span class="text-muted text-sm" id="result-count"><%= jobs.length %> job<%= jobs.length!==1?'s':'' %> found</span>
  </div>

  <!-- Job grid -->
  <div class="grid-3" id="job-grid">
    <% if (!jobs.length) { %>
      <div class="empty-state" style="grid-column:1/-1">
        <div class="empty-state-icon">◎</div>
        <h3>No jobs found</h3>
        <p>Try adjusting your filters or check back soon.</p>
      </div>
    <% } else { %>
      <% jobs.forEach(j => { %>
      <div style="position:relative">
        <a href="/jobs/<%= j.id %>" class="job-card card-lift" style="display:block">
          <div class="flex items-center justify-between mb-8">
            <span class="badge badge-open"><%= j.category_icon || '✦' %> <%= j.category_name || 'General' %></span>
            <% if (j.match_score >= 70) { %>
              <span class="match-score <%= j.match_score>=80?'high':'med' %>"><%= j.match_score %>% match</span>
            <% } %>
          </div>
          <div class="job-card-title"><%= j.title %></div>
          <div class="job-card-meta">
            <span>by <%= j.client_name %></span>
            <span><%= j.proposal_count %> proposal<%= j.proposal_count!==1?'s':'' %></span>
          </div>
          <% if (j.skills_text) { %>
            <div class="flex gap-8 mt-8" style="flex-wrap:wrap">
              <% j.skills_text.split(',').slice(0,3).forEach(s => { %>
                <span class="skill-tag"><%= s.trim() %></span>
              <% }) %>
            </div>
          <% } %>
          <div class="flex items-center justify-between mt-16">
            <span class="job-card-budget">$<%= Number(j.budget_min).toLocaleString() %>–$<%= Number(j.budget_max).toLocaleString() %></span>
            <span class="badge badge-<%= j.level %>"><%= j.level %></span>
          </div>
        </a>
        <!-- Save button (outside the <a> to prevent navigation) -->
        <form action="/freelancer/jobs/<%= j.id %>/save" method="POST"
          style="position:absolute;top:10px;right:10px">
          <button type="submit" class="save-btn <%= j.is_saved ? 'saved' : '' %>"
            title="<%= j.is_saved ? 'Remove from saved' : 'Save job' %>">
            <%= j.is_saved ? '★' : '☆' %>
          </button>
        </form>
      </div>
      <% }) %>
    <% } %>
  </div>

</div>
<%- include('../layouts/footer') %>
