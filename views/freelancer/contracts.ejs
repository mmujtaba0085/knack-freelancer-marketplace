<%- include('../layouts/header', { title: 'My Contracts' }) %>
<div class="container" style="padding-top:40px;padding-bottom:64px">
  <h1 style="font-family:var(--font-serif);font-size:32px;margin-bottom:32px">Contracts</h1>

  <% if (!contracts.length) { %>
    <div class="empty-state">
      <div class="empty-state-icon">◇</div>
      <h3>No contracts yet</h3>
      <p>Submit proposals to get hired and create your first contract.</p>
      <a href="/freelancer/browse" class="btn btn-primary">Find work</a>
    </div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:16px">
      <% contracts.forEach(ct => { %>
      <a href="/contracts/<%= ct.id %>" class="card card-lift" style="display:block">
        <div class="flex items-center justify-between" style="flex-wrap:wrap;gap:12px;margin-bottom:16px">
          <div>
            <div style="font-weight:600;font-size:16px"><%= ct.job_title %></div>
            <div class="text-muted text-sm mt-8">Client: <%= ct.client_name %></div>
          </div>
          <div style="text-align:right">
            <div style="font-family:var(--font-serif);font-size:20px">$<%= Number(ct.agreed_budget).toLocaleString() %></div>
            <span class="badge badge-<%= ct.status %>" style="margin-top:4px"><%= ct.status %></span>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <div class="progress-track" style="flex:1">
            <div class="progress-fill <%= ct.milestone_pct>=100?'complete':'' %>" style="width:<%= ct.milestone_pct %>%"></div>
          </div>
          <span class="text-sm text-muted"><%= ct.milestone_pct %>% complete</span>
        </div>
      </a>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../layouts/footer') %>
