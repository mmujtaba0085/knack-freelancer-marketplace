<%- include('../layouts/header', { title: 'Edit Job' }) %>
<div class="container-sm" style="padding-top:48px;padding-bottom:64px">
  <div class="page-header">
    <a href="/client/jobs" class="text-sm text-muted" style="display:inline-block;margin-bottom:8px">← My jobs</a>
    <h1>Edit job</h1>
  </div>

  <% if (errors && errors.length) { %>
    <div class="alert alert-error">
      <% errors.forEach(e => { %><div>⚠ <%= e.msg %></div><% }) %>
    </div>
  <% } %>

  <form action="/client/jobs/<%= job.id %>/edit" method="POST" novalidate>
    <div style="display:flex;flex-direction:column;gap:20px">
      <div class="form-group">
        <label class="form-label">Title</label>
        <input class="form-input" type="text" name="title" value="<%= job.title %>" required>
      </div>
      <div class="form-group">
        <label class="form-label">Category</label>
        <select class="form-select" name="category_id">
          <option value="">None</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>" <%= job.category_id==c.id?'selected':'' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Description</label>
        <textarea class="form-textarea" name="description" rows="7" required><%= job.description %></textarea>
      </div>
      <div class="grid-2" style="gap:16px">
        <div class="form-group">
          <label class="form-label">Min budget ($)</label>
          <input class="form-input" type="number" name="budget_min" value="<%= job.budget_min %>" min="1" required>
        </div>
        <div class="form-group">
          <label class="form-label">Max budget ($)</label>
          <input class="form-input" type="number" name="budget_max" value="<%= job.budget_max %>" min="1" required>
        </div>
      </div>
      <div class="grid-2" style="gap:16px">
        <div class="form-group">
          <label class="form-label">Level</label>
          <select class="form-select" name="level">
            <option value="entry"        <%= job.level==='entry'?'selected':'' %>>Entry</option>
            <option value="intermediate" <%= job.level==='intermediate'?'selected':'' %>>Intermediate</option>
            <option value="expert"       <%= job.level==='expert'?'selected':'' %>>Expert</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Deadline</label>
          <input class="form-input" type="date" name="deadline" value="<%= job.deadline ? new Date(job.deadline).toISOString().split('T')[0] : '' %>">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Skills (comma-separated)</label>
        <input class="form-input" type="text" name="skills_text" value="<%= job.skills_text||'' %>">
      </div>
      <div class="flex gap-12">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a href="/client/jobs" class="btn btn-ghost">Cancel</a>
      </div>
    </div>
  </form>
</div>
<%- include('../layouts/footer') %>
<script src="/js/validate.js"></script>
