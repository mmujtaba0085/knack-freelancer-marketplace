<%- include('../layouts/header', { title: 'Proposals for ' + job.title }) %>
<div class="container" style="padding-top:40px;padding-bottom:64px">
  <a href="/client/jobs" class="text-sm text-muted" style="display:inline-block;margin-bottom:16px">← My jobs</a>

  <div class="page-header">
    <div class="flex items-center justify-between" style="flex-wrap:wrap;gap:16px">
      <div>
        <h1><%= job.title %></h1>
        <div class="flex gap-12 mt-8" style="flex-wrap:wrap">
          <span class="badge badge-<%= job.status.replace('_','-') %>"><%= job.status %></span>
          <span class="text-muted text-sm">Budget: $<%= Number(job.budget_min).toLocaleString() %>–$<%= Number(job.budget_max).toLocaleString() %></span>
          <span class="text-muted text-sm"><%= proposals.length %> proposal<%= proposals.length!==1?'s':'' %></span>
        </div>
      </div>
    </div>
  </div>

  <% if (!proposals.length) { %>
    <div class="empty-state">
      <div class="empty-state-icon">✦</div>
      <h3>No proposals yet</h3>
      <p>Your job was just posted. Freelancers will start applying soon.</p>
    </div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:20px">
      <% proposals.forEach(p => { %>
      <div class="card">
        <div class="flex items-center justify-between" style="flex-wrap:wrap;gap:16px;margin-bottom:16px">
          <div class="flex items-center gap-16">
            <img src="/img/default-avatar.svg" alt="<%= p.freelancer_name %>" style="width:48px;height:48px;border-radius:50%;border:2px solid var(--line)">
            <div>
              <a href="/profile/<%= p.freelancer_id %>" style="font-weight:600;font-size:16px"><%= p.freelancer_name %></a>
              <div class="text-muted text-sm mt-8"><%= p.headline || 'Freelancer' %> <% if(p.location){%>· <%= p.location %><% } %></div>
              <div class="flex gap-8 mt-8 items-center">
                <div class="stars">
                  <% for(let i=1;i<=5;i++){%><span class="star <%= i<=Math.round(p.avg_rating)?'filled':''%>">★</span><%}%>
                </div>
                <span class="text-sm text-muted">(<%= p.review_count %> reviews)</span>
              </div>
            </div>
          </div>
          <div style="text-align:right">
            <div style="font-family:var(--font-serif);font-size:24px">$<%= Number(p.proposed_budget).toLocaleString() %></div>
            <div class="text-muted text-sm"><%= p.estimated_days %> day<%= p.estimated_days!==1?'s':'' %> delivery</div>
            <span class="badge badge-<%= p.status %>" style="margin-top:6px"><%= p.status %></span>
          </div>
        </div>

        <div style="background:var(--paper);border-radius:var(--radius);padding:16px;margin-bottom:16px;font-size:14px;line-height:1.7;color:var(--ink-2)">
          <%- p.cover_letter.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>') %>
        </div>

        <div class="flex gap-12" style="flex-wrap:wrap">
          <% if (p.status === 'pending') { %>
          <form action="/proposals/<%= p.id %>/accept" method="POST">
            <button type="submit" class="btn btn-success btn-sm"
              data-confirm="Hire <%= p.freelancer_name %>? This will create a contract.">✓ Accept proposal</button>
          </form>
          <form action="/proposals/<%= p.id %>/reject" method="POST">
            <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--danger)"
              data-confirm="Reject this proposal?">✕ Decline</button>
          </form>
          <% } %>
          <a href="/proposals/<%= p.id %>/chat" class="btn btn-outline btn-sm">💬 Message</a>
          <a href="/profile/<%= p.freelancer_id %>" class="btn btn-outline btn-sm">View profile</a>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../layouts/footer') %>
