<%- include('../layouts/header', { title: 'User Management' }) %>
<div class="container" style="padding-top:40px;padding-bottom:64px">

  <div class="flex items-center justify-between" style="margin-bottom:28px;flex-wrap:wrap;gap:16px">
    <h1 style="font-family:var(--font-serif);font-size:32px">User Management</h1>
    <span class="text-muted text-sm"><%= users.length %> user<%= users.length!==1?'s':'' %> found</span>
  </div>

  <!-- Search & filter -->
  <form method="GET" action="/admin/users" style="display:grid;grid-template-columns:1fr auto auto;gap:12px;margin-bottom:24px;align-items:end">
    <div class="form-group" style="margin:0">
      <label class="form-label">Search users</label>
      <input class="form-input" type="text" name="q" value="<%= q %>" placeholder="Name or email…">
    </div>
    <div class="form-group" style="margin:0;min-width:140px">
      <label class="form-label">Role</label>
      <select class="form-select" name="role">
        <option value="">All roles</option>
        <option value="client"     <%= role==='client'?'selected':'' %>>Client</option>
        <option value="freelancer" <%= role==='freelancer'?'selected':'' %>>Freelancer</option>
        <option value="admin"      <%= role==='admin'?'selected':'' %>>Admin</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary" style="align-self:end">Search</button>
  </form>

  <div class="card" style="padding:0;overflow:hidden">
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>User</th>
            <th>Email</th>
            <th>Role</th>
            <th>Rating</th>
            <th>Status</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!users.length) { %>
          <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--ink-3)">No users found</td></tr>
          <% } %>
          <% users.forEach(u => { %>
          <tr>
            <td>
              <div style="font-weight:500"><%= u.name %></div>
              <% if (u.headline) { %><div class="text-muted text-sm"><%= u.headline %></div><% } %>
            </td>
            <td class="text-muted text-sm"><%= u.email %></td>
            <td>
              <!-- Role change form (Criterion 10) -->
              <form action="/admin/users/<%= u.id %>/role" method="POST" style="display:inline">
                <select class="form-select" name="role" onchange="this.form.submit()"
                  style="padding:4px 8px;font-size:12px;border-radius:999px;min-width:110px">
                  <option value="client"     <%= u.role==='client'    ?'selected':'' %>>Client</option>
                  <option value="freelancer" <%= u.role==='freelancer'?'selected':'' %>>Freelancer</option>
                  <option value="admin"      <%= u.role==='admin'     ?'selected':'' %>>Admin</option>
                </select>
              </form>
            </td>
            <td>
              <% if (u.review_count > 0) { %>
                <div class="flex items-center gap-4">
                  <span style="color:#F59E0B">★</span>
                  <span style="font-size:13px"><%= Number(u.avg_rating).toFixed(1) %></span>
                  <span class="text-muted text-sm">(<%= u.review_count %>)</span>
                </div>
              <% } else { %>
                <span class="text-muted text-sm">—</span>
              <% } %>
            </td>
            <td>
              <span class="badge <%= u.is_active ? 'badge-accepted' : 'badge-rejected' %>">
                <%= u.is_active ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td class="text-muted text-sm"><%= new Date(u.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></td>
            <td>
              <div class="flex gap-8">
                <a href="/profile/<%= u.id %>" class="btn btn-ghost btn-sm">Profile</a>
                <!-- Activate / Deactivate (Criterion 10) -->
                <form action="/admin/users/<%= u.id %>/toggle-active" method="POST" style="display:inline">
                  <button type="submit" class="btn btn-sm <%= u.is_active ? 'btn-danger' : 'btn-success' %>"
                    data-confirm="<%= u.is_active ? 'Deactivate' : 'Activate' %> <%= u.name %>?">
                    <%= u.is_active ? 'Deactivate' : 'Activate' %>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../layouts/footer') %>
