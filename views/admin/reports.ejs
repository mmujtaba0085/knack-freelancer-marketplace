<%- include('../layouts/header', { title: 'Reports' }) %>
<div class="container" style="padding-top:40px;padding-bottom:64px">
  <h1 style="font-family:var(--font-serif);font-size:32px;margin-bottom:32px">Platform Reports</h1>

  <div class="grid-2" style="gap:24px;margin-bottom:32px">
    <div class="chart-card">
      <h3>Monthly GMV ($)</h3>
      <canvas id="gmvChart" height="200"></canvas>
    </div>
    <div class="chart-card">
      <h3>Jobs by category</h3>
      <canvas id="categoryChart" height="200"></canvas>
    </div>
  </div>

  <!-- GMV table -->
  <div class="card" style="padding:0;overflow:hidden">
    <div style="padding:20px 24px;border-bottom:1px solid var(--line)">
      <h3 style="font-size:15px;font-weight:600">Monthly breakdown</h3>
    </div>
    <div class="table-wrap">
      <table class="table">
        <thead><tr><th>Month</th><th>GMV ($)</th><th>Contracts</th></tr></thead>
        <tbody>
          <% monthlyGmv.forEach(row => { %>
          <tr>
            <td><%= row.month %></td>
            <td style="font-family:var(--font-serif);font-size:16px">$<%= Number(row.gmv).toLocaleString() %></td>
            <td><%= row.contracts %></td>
          </tr>
          <% }) %>
          <% if (!monthlyGmv.length) { %>
          <tr><td colspan="3" style="text-align:center;padding:32px;color:var(--ink-3)">No data yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../layouts/footer') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
  const gmv  = <%- JSON.stringify(monthlyGmv) %>;
  const cats = <%- JSON.stringify(categoryStats) %>;

  new Chart(document.getElementById('gmvChart'), {
    type: 'line',
    data: {
      labels: gmv.map(d => d.month),
      datasets: [{ data: gmv.map(d => d.gmv), borderColor: '#FF6B2C', backgroundColor: 'rgba(255,107,44,.1)', fill: true, tension: 0.4, borderWidth: 2.5, pointBackgroundColor: '#FF6B2C' }]
    },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { ticks: { callback: v => '$'+v } } } }
  });

  new Chart(document.getElementById('categoryChart'), {
    type: 'doughnut',
    data: {
      labels: cats.map(c => c.name),
      datasets: [{ data: cats.map(c => c.job_count), backgroundColor: ['#FF6B2C','#14110D','#1F8A5C','#2563A6','#F59E0B','#8B5CF6','#EC4899','#6B7280'] }]
    },
    options: { responsive: true, plugins: { legend: { position: 'right' } } }
  });
</script>
