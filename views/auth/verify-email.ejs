<%- include('../layouts/header', { title: 'Verify your email' }) %>
<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">Knack<span>.</span></div>
    <h1 class="auth-title">Check your inbox</h1>
    <p class="auth-sub">We sent a 6-digit code to <strong><%= masked %></strong>. Enter it below to activate your account.</p>

    <% if (locals.resent) { %>
      <div class="alert alert-success">✓ A new code has been sent.</div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/verify-email" method="POST" style="margin-top:24px">
      <div style="display:flex;flex-direction:column;gap:16px">
        <div class="form-group">
          <label class="form-label" for="code">Verification code</label>
          <input
            class="form-input"
            type="text"
            id="code"
            name="code"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            placeholder="123456"
            autocomplete="one-time-code"
            style="font-size:28px;letter-spacing:10px;text-align:center"
            required
            autofocus>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Verify &amp; continue</button>
      </div>
    </form>

    <form action="/resend-code" method="POST" style="margin-top:16px">
      <button type="submit" class="btn btn-ghost btn-full">Resend code</button>
    </form>
  </div>
</div>
<%- include('../layouts/footer') %>
