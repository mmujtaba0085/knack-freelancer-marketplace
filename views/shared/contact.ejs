<%- include('../layouts/header', { title: 'Contact' }) %>
<div class="container" style="padding-top:64px;padding-bottom:80px">
  <div class="grid-2" style="gap:64px;align-items:start;max-width:900px;margin:0 auto">

    <div>
      <h1 class="display-lg" style="margin-bottom:16px">Get in touch</h1>
      <p style="color:var(--ink-2);line-height:1.8;margin-bottom:32px">
        Have a question, feedback, or want to partner with us? We'd love to hear from you. Our team typically responds within one business day.
      </p>

      <div style="display:flex;flex-direction:column;gap:24px">
        <div class="flex items-center gap-16">
          <div style="width:44px;height:44px;background:var(--sunken);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">✉</div>
          <div>
            <div style="font-weight:500;font-size:14px">Email</div>
            <div style="color:var(--ink-3);font-size:14px">hello@knack.work</div>
          </div>
        </div>
        <div class="flex items-center gap-16">
          <div style="width:44px;height:44px;background:var(--sunken);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">◎</div>
          <div>
            <div style="font-weight:500;font-size:14px">Social</div>
            <div style="color:var(--ink-3);font-size:14px">@knack_work on 𝕏 and LinkedIn</div>
          </div>
        </div>
        <div class="flex items-center gap-16">
          <div style="width:44px;height:44px;background:var(--sunken);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">◇</div>
          <div>
            <div style="font-weight:500;font-size:14px">Headquarters</div>
            <div style="color:var(--ink-3);font-size:14px">Lisbon, Portugal (remote-first)</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <% if (sent) { %>
        <div style="text-align:center;padding:32px 0">
          <div style="font-size:48px;margin-bottom:16px">✓</div>
          <h3 style="font-family:var(--font-serif);font-size:24px;margin-bottom:8px">Message sent!</h3>
          <p class="text-muted">We'll get back to you within one business day.</p>
          <a href="/" class="btn btn-outline btn-sm" style="margin-top:20px">Back to home</a>
        </div>
      <% } else { %>
        <h3 style="font-family:var(--font-serif);font-size:22px;margin-bottom:20px">Send us a message</h3>

        <% if (errors && errors.length) { %>
          <div class="alert alert-error"><%= errors[0].msg %></div>
        <% } %>

        <form action="/contact" method="POST" novalidate>
          <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
              <label class="form-label">Name</label>
              <input class="form-input" type="text" name="name" value="<%= body.name||'' %>" required placeholder="Your name">
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <input class="form-input" type="email" name="email" value="<%= body.email||'' %>" required placeholder="you@example.com">
            </div>
            <div class="form-group">
              <label class="form-label">Subject</label>
              <select class="form-select" name="subject">
                <option>General enquiry</option>
                <option>I need help with my account</option>
                <option>Partnership / press</option>
                <option>Report a bug</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Message</label>
              <textarea class="form-textarea" name="message" rows="5" required placeholder="Tell us what's on your mind…"><%= body.message||'' %></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-full">Send message</button>
          </div>
        </form>
      <% } %>
    </div>
  </div>
</div>
<%- include('../layouts/footer') %>
<script src="/js/validate.js"></script>
