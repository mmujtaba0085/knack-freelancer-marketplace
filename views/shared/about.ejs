<%- include('../layouts/header', { title: 'About Knack' }) %>

<!-- Hero -->
<section style="background:var(--ink);color:var(--paper);padding:100px 0 80px">
  <div class="container-sm" style="text-align:center">
    <div style="font-family:var(--font-serif);font-size:14px;color:#7A7069;text-transform:uppercase;letter-spacing:.1em;margin-bottom:24px">Our story</div>
    <h1 style="font-family:var(--font-serif);font-size:clamp(36px,6vw,72px);line-height:1.1;color:var(--paper);margin-bottom:24px">
      Work is more meaningful<br>when it's <em style="color:var(--brand)">done well.</em>
    </h1>
    <p style="font-size:18px;color:#B5AFA7;line-height:1.8;max-width:560px;margin:0 auto">
      Knack was built for people who care about the quality of their work — on both sides of the transaction.
    </p>
  </div>
</section>

<!-- Mission -->
<section class="section">
  <div class="container-sm">
    <div class="grid-2" style="gap:64px;align-items:center">
      <div>
        <h2 class="display-md" style="margin-bottom:20px">Why we exist</h2>
        <p style="color:var(--ink-2);line-height:1.8;margin-bottom:16px">
          Most freelance platforms are built around volume. More jobs, more freelancers, more noise. The good work gets lost in the race to the bottom on price.
        </p>
        <p style="color:var(--ink-2);line-height:1.8;margin-bottom:16px">
          Knack is different. We believe the best freelancers deserve clients who value their craft, and the best clients deserve collaborators who treat their project like their own.
        </p>
        <p style="color:var(--ink-2);line-height:1.8">
          We built the platform we wished existed.
        </p>
      </div>
      <div style="background:var(--sunken);border-radius:var(--radius-lg);padding:40px;text-align:center">
        <div style="font-family:var(--font-serif);font-size:64px;color:var(--brand);line-height:1">✦</div>
        <div style="font-family:var(--font-serif);font-size:28px;margin-top:16px;color:var(--ink)">Knack.</div>
        <div style="color:var(--ink-3);margin-top:8px;font-size:14px">The marketplace for serious work.</div>
      </div>
    </div>
  </div>
</section>

<!-- Values -->
<section class="section" style="background:var(--sunken)">
  <div class="container">
    <h2 class="display-md" style="text-align:center;margin-bottom:48px">What we stand for</h2>
    <div class="grid-3">
      <div class="card" style="text-align:center;padding:36px 28px">
        <div style="font-size:36px;margin-bottom:16px">◇</div>
        <h3 style="font-size:18px;font-weight:600;margin-bottom:10px">Quality over quantity</h3>
        <p class="text-muted" style="font-size:14px;line-height:1.7">We'd rather have fewer, better projects than a feed of noise. Every job on Knack is reviewed before it goes live.</p>
      </div>
      <div class="card" style="text-align:center;padding:36px 28px">
        <div style="font-size:36px;margin-bottom:16px">✦</div>
        <h3 style="font-size:18px;font-weight:600;margin-bottom:10px">Transparency</h3>
        <p class="text-muted" style="font-size:14px;line-height:1.7">Escrow milestones, clear contracts, honest reviews. No surprises on either side.</p>
      </div>
      <div class="card" style="text-align:center;padding:36px 28px">
        <div style="font-size:36px;margin-bottom:16px">◎</div>
        <h3 style="font-size:18px;font-weight:600;margin-bottom:10px">Fair to freelancers</h3>
        <p class="text-muted" style="font-size:14px;line-height:1.7">Freelancers are partners, not a commodity. We protect their time, their rates, and their reputation.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section">
  <div class="container-sm" style="text-align:center">
    <h2 class="display-md" style="margin-bottom:16px">Ready to do your best work?</h2>
    <p class="text-muted" style="margin-bottom:32px">Join thousands of clients and freelancers on Knack.</p>
    <div class="flex gap-16" style="justify-content:center;flex-wrap:wrap">
      <a href="/signup" class="btn btn-primary btn-lg">Get started — it's free</a>
      <a href="/contact" class="btn btn-outline btn-lg">Talk to us</a>
    </div>
  </div>
</section>

<%- include('../layouts/footer') %>
